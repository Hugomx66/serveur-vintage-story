# URL HTTPS du repo GitHub (vide) qui servira a stocker la sauvegarde du serveur
# Exemple : https://github.com/ton-compte/vintagestory-save.git
GIT_REPO_URL=

# Personal Access Token GitHub (scope "repo") utilise pour le push automatique
GIT_TOKEN=

# Branche cible du repo de sauvegarde
GIT_BRANCH=main

# Identite utilisee pour les commits automatiques
GIT_USER_NAME=VintageStoryServer
GIT_USER_EMAIL=vintagestory@server.local
